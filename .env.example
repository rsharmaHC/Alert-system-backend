# Application Settings
APP_NAME=TM Alert
APP_ENV=development

# JWT Secret Keys (min 32 characters each)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
REFRESH_SECRET_KEY=

# Dedicated key for MFA challenge tokens (5-minute JWTs issued during login)
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
MFA_CHALLENGE_SECRET_KEY=

# Dedicated key for safety check-in tokens (links emailed/SMSed to
# employees). Keeping this separate from SECRET_KEY means rotating it
# after a leaked check-in link does not invalidate every active session
# (security review B-M2). Falls back to SECRET_KEY if unset.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
CHECKIN_SECRET_KEY=

# Token expiration settings
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Development-only MFA exemption: comma-separated emails that skip the
# role-based MFA requirement. Only honoured when APP_ENV=development.
# Leave empty in prod. Example: admin@tmalert.com,localdev@example.com
MFA_EXEMPT_EMAILS=

# Database Configuration
# POSTGRES_* are consumed by docker-compose to provision the local Postgres
# container; DATABASE_URL is what the app actually connects with. Keep the
# credentials consistent if you change either (e.g. rotate a dev password).
POSTGRES_USER=postgres
# REQUIRED: generate a strong password before first run. Example:
#   python -c "import secrets; print(secrets.token_urlsafe(24))"
# Leaving this at the example default is rejected by the database container.
POSTGRES_PASSWORD=
POSTGRES_DB=tm_alert
# Substitute the password you set above. The app refuses to start with an
# empty or example credential string.
DATABASE_URL=postgresql://postgres:REPLACE_ME@localhost:5432/tm_alert

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# Frontend/Backend URLs
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# Twilio Configuration (SMS notifications)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# AWS SES Configuration (Email notifications)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
SES_FROM_EMAIL=noreply@tmalert.com
SES_FROM_NAME=TM Alert

# SMTP Configuration (Async email notifications)
EMAIL_FROM=security@tmalert.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Google Maps API (optional - for other map features)
GOOGLE_MAPS_API_KEY=

# ── Geocoding Provider ────────────────────────────────────────────────
# DEFAULT (demo — no key needed, global coverage):
GEOCODING_PROVIDER=photon_public

# Self-hosted Photon on Railway:
# GEOCODING_PROVIDER=photon_self
# GEOCODING_PROVIDER_URL=http://photon.railway.internal:2322

# Self-hosted Photon on VPS (production):
# GEOCODING_PROVIDER=photon_self
# GEOCODING_PROVIDER_URL=https://photon.yourdomain.com

GEOCODING_PROVIDER_URL=

# Slack/Teams Webhooks
SLACK_DEFAULT_WEBHOOK_URL=
TEAMS_DEFAULT_WEBHOOK_URL=

# MFA Encryption Key (Fernet key for encrypting MFA secrets at rest)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MFA_ENCRYPTION_KEY=

# =============================================================================
# Authentication Providers Configuration
# =============================================================================
# Comma-separated list of enabled auth providers: local, entra, ldap
# - local: Email/password authentication
# - entra: Microsoft Entra ID (Azure AD) SSO
# - ldap: LDAP/Active Directory authentication
AUTH_PROVIDERS=local,entra,ldap

# Control individual provider availability (true/false)
ENTRA_ENABLED=true
LDAP_ENABLED=false
LOCAL_ENABLED=true

# =============================================================================
# Microsoft Entra ID (Azure AD) OAuth 2.0 / OIDC Configuration
# =============================================================================
# Required for Microsoft SSO login
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
ENTRA_TENANT_ID=

# Must match exactly what's configured in Azure AD app registration
# Format: http://localhost:8000/api/v1/auth/entra/callback (development)
#         https://yourdomain.com/api/v1/auth/entra/callback (production)
ENTRA_REDIRECT_URI=

# Optional: Restrict login to specific email domains only
# Comma-separated list (e.g., "company.com,subsidiary.com")
# Leave empty to allow any domain
ENTRA_ALLOWED_EMAIL_DOMAINS=

# =============================================================================
# LDAP / Active Directory Configuration
# =============================================================================
# Required for LDAP authentication
# Server URL with protocol (ldap:// or ldaps:// for secure)
LDAP_SERVER_URL=ldaps://ad.company.com:636

# Service account credentials for LDAP binding
# Use a dedicated service account with read-only access to user directory
LDAP_BIND_DN=cn=tmalert-service,ou=ServiceAccounts,dc=company,dc=com
LDAP_BIND_PASSWORD=

# Base DN where user accounts are located
LDAP_USER_SEARCH_BASE=ou=Users,dc=company,dc=com

# LDAP search filter to find user by username
# {username} is replaced with the entered username
# Common examples:
#   Active Directory: (&(objectClass=user)(sAMAccountName={username}))
#   OpenLDAP: (&(objectClass=person)(uid={username}))
LDAP_USER_SEARCH_FILTER=(&(objectClass=user)(sAMAccountName={username}))

# Attribute mappings for user information
LDAP_EMAIL_ATTRIBUTE=mail
LDAP_FIRST_NAME_ATTRIBUTE=givenName
LDAP_LAST_NAME_ATTRIBUTE=sn

# TLS/SSL configuration (recommended for production)
LDAP_USE_TLS=true
LDAP_TLS_REQUIRE_CERT=demand  # Options: never, allow, try, demand, hard

# Optional: LDAP group-based role assignment
# Leave empty to disable group-based roles (all users get VIEWER role)
# LDAP_ADMIN_GROUP_DN=cn=TMAlert-Admins,ou=Groups,dc=company,dc=com
# LDAP_MANAGER_GROUP_DN=cn=TMAlert-Managers,ou=Groups,dc=company,dc=com

# =============================================================================
# Security Settings
# =============================================================================
# Rate limiting for password reset (seconds)
PASSWORD_RESET_RATE_LIMIT_SECONDS=60

# Allowed email domains for local authentication (optional)
# Comma-separated list. Leave empty to allow all domains.
# Example: ALLOWED_EMAIL_DOMAINS=company.com,subsidiary.com
ALLOWED_EMAIL_DOMAINS=

# Auto-provision users on first SSO login (true/false)
# If false, users must be created by admin before they can login
AUTO_PROVISION_USERS=true
