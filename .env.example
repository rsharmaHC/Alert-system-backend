# Application Settings
APP_NAME=TM Alert
APP_ENV=development

# JWT Secret Keys (min 32 characters each)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
REFRESH_SECRET_KEY=

# Dedicated key for MFA challenge tokens (5-minute JWTs issued during login)
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
MFA_CHALLENGE_SECRET_KEY=

# Token expiration settings
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database Configuration
DATABASE_URL=postgresql://postgres:password@localhost:5432/tm_alert

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# Frontend/Backend URLs
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# Twilio Configuration (SMS notifications)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# AWS SES Configuration (Email notifications)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
SES_FROM_EMAIL=noreply@tmalert.com
SES_FROM_NAME=TM Alert

# SMTP Configuration (Async email notifications)
EMAIL_FROM=security@tmalert.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Google Maps / Location Services
GOOGLE_MAPS_API_KEY=
LOCATIONIQ_API_KEY=
LOCATIONIQ_BASE_URL=https://api.locationiq.com/v1

# Slack/Teams Webhooks
SLACK_DEFAULT_WEBHOOK_URL=
TEAMS_DEFAULT_WEBHOOK_URL=

# MFA Encryption Key (Fernet key for encrypting MFA secrets at rest)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MFA_ENCRYPTION_KEY=
