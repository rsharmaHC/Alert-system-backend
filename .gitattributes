# Set default behavior to automatically normalize line endings
* text=auto eol=lf

# Explicitly declare native line endings for binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pyc binary
*.pyo binary
*.db binary
*.sqlite binary
*.sqlite3 binary
